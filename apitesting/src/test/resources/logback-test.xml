<configuration>

    <appender name="STDOUT"
              class="ch.qos.logback.core.ConsoleAppender">

        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>

    </appender>

    <logger name="com.apitesting" level="INFO" additivity="">
        <appender-ref ref="STDOUT"/>
    </logger>


    <logger name="io.qameta.allure" level="OFF"/>
    <logger name="io.qameta.allure.AllureLifecycle" level="OFF"/>

    <root level="OFF"/>


    <root level="OFF"/>

</configuration>